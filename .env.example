# Database Configuration (SQLite por defecto)
DATABASE_URL=file:./database.sqlite

# Puerto del servidor
PORT=5000

# Session Secret (cambia esto en produccion)
SESSION_SECRET=your-secret-key-here

# Admin seed credentials (solo se usan si no existe admin en la BD)
ADMIN_EMAIL=admin@endulzarte.com
ADMIN_PASSWORD=admin123

# Node Environment
NODE_ENV=development
